# Copy to ~/.config/worktree-pane/config.env and edit. All optional —
# the script falls back to these same defaults when no file is present.

# Which multiplexer opens the pane: auto | tmux | cmux | none
WORKTREE_PANE_MUX=auto

# Where worktrees live (repo-relative, or an absolute path)
WORKTREE_PANE_ROOT=.claude/worktrees

# Prefix applied to ticket-style names (FOO-123 -> feature/FOO-123).
# Leave blank for no prefix.
WORKTREE_PANE_BRANCH_PREFIX=feature/

# Default base branch for brand-new branches. Blank = auto-detect the repo's
# default branch each time.
WORKTREE_PANE_BASE=
